# Telegram
BOT_TOKEN=your_bot_token_here
MINIAPP_URL=https://yourdomain.com/app

# Database
POSTGRES_USER=tg_studio
POSTGRES_PASSWORD=secret
POSTGRES_DB=tg_studio
DATABASE_URL=postgresql+asyncpg://tg_studio:secret@postgres:5432/tg_studio

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Kaspi Pay (deprecated)
KASPI_MERCHANT_ID=your_merchant_id
KASPI_API_KEY=your_api_key
KASPI_CALLBACK_SECRET=your_callback_secret

# Freedom Pay (credentials хранятся в БД для каждого Business)
FREEDOM_PAY_API_URL=https://api.freedompay.kz
API_PUBLIC_URL=https://yourdomain.com  # Базовый URL API для webhook pg_result_url

# App
DEBUG=false
ALLOWED_HOSTS=yourdomain.com
